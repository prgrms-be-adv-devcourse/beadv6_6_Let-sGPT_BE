{
  "uid": "redis-overview",
  "title": "Redis",
  "tags": ["redis", "openat"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "서버 건강 (층 A)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "메모리 사용률",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes",
          "legendFormat": "used ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "메모리 절대량 추이",
      "description": "redis_memory_max_bytes가 0이면 maxmemory args가 안 먹은 것이므로 그 자체가 설정 검증이다.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "exporter 상태 (redis_up)",
      "description": "0이면 아래 모든 서버 패널이 무의미하다는 표시.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_up",
          "legendFormat": "redis_up"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "쓰기 거부 (OOM)",
      "description": "이 장에서 가장 중요한 패널. noeviction 상태에서 200MB가 찼을 때 유일하게 즉시 반응하는 신호다. 0이 아니면 그 순간 재고 차감과 대기열 쓰기가 실패하고 있다는 뜻이다.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(redis_errors_total{err=\"OOM\"}[5m])",
          "legendFormat": "OOM"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "오류 유형 분포",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (err) (rate(redis_errors_total[5m]))",
          "legendFormat": "{{err}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "축출/만료",
      "description": "noeviction이므로 evicted는 상시 0이어야 한다. 0이 아니면 정책이 의도와 다르게 적용된 것이다.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(redis_evicted_keys_total[5m])",
          "legendFormat": "evicted"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(redis_expired_keys_total[5m])",
          "legendFormat": "expired"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "접속 클라이언트",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_connected_clients",
          "legendFormat": "connected"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_blocked_clients",
          "legendFormat": "blocked"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "캐시 적중률",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "키 개수",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_db_keys{db=\"db0\"}",
          "legendFormat": "keys"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_db_keys_expiring{db=\"db0\"}",
          "legendFormat": "expiring"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "커맨드별 (층 A 서버 시점 + 층 B 클라이언트 시점)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "서버 시점 처리량 상위",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, sum by (cmd) (rate(redis_commands_total[5m])))",
          "legendFormat": "{{cmd}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "서버 시점 평균 지연",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(redis_commands_duration_seconds_total[5m]) / rate(redis_commands_total[5m])",
          "legendFormat": "{{cmd}}"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "서버 시점 분위수 (Lua)",
      "description": "eval/evalsha 지연 전용.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "µs" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_latency_percentiles_usec{cmd=~\"eval.*|evalsha\"}",
          "legendFormat": "{{cmd}} p{{quantile}}"
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "서버 시점 실패/거부",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (cmd) (rate(redis_commands_failed_calls_total[5m]))",
          "legendFormat": "failed {{cmd}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (cmd) (rate(redis_commands_rejected_calls_total[5m]))",
          "legendFormat": "rejected {{cmd}}"
        }
      ]
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "서비스별 × 커맨드별 처리량 (층 B)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (app, db_operation) (rate(lettuce_seconds_count[5m]))",
          "legendFormat": "{{app}} / {{db_operation}}"
        }
      ]
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "서비스별 × 커맨드별 평균 지연 (층 B)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (app, db_operation) (rate(lettuce_seconds_sum[5m])) / sum by (app, db_operation) (rate(lettuce_seconds_count[5m]))",
          "legendFormat": "{{app}} / {{db_operation}}"
        }
      ]
    },
    {
      "id": 27,
      "type": "timeseries",
      "title": "EVALSHA 평균 지연 (층 B)",
      "description": "Lua가 느린 게 queue냐 product냐에 답하는 패널. net_sock_peer_addr(파드 IP) 라벨은 무시하고 app/db_operation으로만 집계한다.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (app, db_operation) (rate(lettuce_seconds_sum{db_operation=\"EVALSHA\"}[5m])) / sum by (app, db_operation) (rate(lettuce_seconds_count{db_operation=\"EVALSHA\"}[5m]))",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "id": 28,
      "type": "timeseries",
      "title": "서비스별 오류 (층 B)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (app, db_operation) (rate(lettuce_seconds_count{error!=\"none\"}[5m]))",
          "legendFormat": "{{app}} / {{db_operation}}"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "도메인 사용량",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 }
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "prefix별 키 개수 (키 그룹 켠 경우)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 51 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_key_group_count{db=\"db0\"}",
          "legendFormat": "{{key_group}}"
        }
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "prefix별 메모리 (키 그룹 켠 경우)",
      "description": "redis_memory_used_bytes와 합이 대략 맞는지 눈으로 검증 가능하다.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 51 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_key_group_memory_usage_bytes{db=\"db0\"}",
          "legendFormat": "{{key_group}}"
        }
      ]
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "키 그룹 집계 소요",
      "description": "이 기능 자체의 비용 감시. 500ms를 넘으면 배치 크기를 낮추고, 그래도 안 되면 끈다.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 51 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "redis_last_key_groups_scrape_duration_milliseconds",
          "legendFormat": "scrape ms"
        }
      ]
    },
    {
      "id": 44,
      "type": "timeseries",
      "title": "큐 게이지 3종",
      "description": "QueueMetricsConfig.ensureRegistered가 dropId를 해제하지 않아 시리즈가 단조증가하므로 topk(10)으로 표시를 제한한다. queue_outstanding은 outstanding:{dropId} 키를 그대로 읽으므로 위 prefix별 키 개수와 교차 검증 가능.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 59 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, queue_waiting_size)",
          "legendFormat": "waiting {{dropId}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, queue_outstanding)",
          "legendFormat": "outstanding {{dropId}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, queue_stock_remaining)",
          "legendFormat": "stock {{dropId}}"
        }
      ]
    }
  ]
}
