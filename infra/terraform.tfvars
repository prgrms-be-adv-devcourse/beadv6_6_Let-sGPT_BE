aws_region   = "ap-northeast-2"
project_name = "dropcommerce-bootcamp"

# ---------------------------------------------------------------------
# 네트워크
# ---------------------------------------------------------------------
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
availability_zone  = "ap-northeast-2a"

# ---------------------------------------------------------------------
# EC2
# 세미 프로젝트: t3.large 1대만 활성화.
# 파이널 확장 시 아래 주석을 해제하여 t3.medium 1대를 추가한다 (코드 수정 불필요).
# ---------------------------------------------------------------------
ec2_instances = {
  semi = {
    instance_type    = "t3.large"
    root_volume_size = 50
  }
  # final = {
  #   instance_type    = "t3.medium"
  #   root_volume_size = 50
  # }
}

# ---------------------------------------------------------------------
# SSH
# ---------------------------------------------------------------------
ssh_port = 49222

# 세미: 팀원 접속을 위해 넓게 허용 (예: ["0.0.0.0/0"])
# 파이널: 본인/팀 공인 IP로 좁힐 것 (예: ["1.2.3.4/32"])
# TODO: 값을 채우기 전까지는 SSH 인바운드 규칙이 생성되지 않는다.
ssh_allowed_cidrs = []

# 팀원/배포용 SSH 공개키 목록 (개인키는 절대 넣지 말 것)
ssh_public_keys = [
  # "ssh-ed25519 AAAA... user1@example.com",
  # "ssh-ed25519 AAAA... user2@example.com",
]

deployer_user = "deployer"

# ---------------------------------------------------------------------
# S3
# 전역적으로 유일해야 하는 이름으로 변경할 것 (placeholder)
# ---------------------------------------------------------------------
s3_bucket_name = "dropcommerce-bootcamp-CHANGE-ME"
s3_app_prefix  = "app/"
