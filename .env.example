# 포트 참고용 (회원 9100, 상품 9110, 주문 9120, 결제 9130, 정산 9140)
# 스키마 참고용 (각 도메인 스키마: member, product, order, payment, settlement)
DB_HOST=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
DB_NAME=openat
KAFKA_BROKER=kafka:9092
REDIS_HOST=redis
REDIS_PORT=6379
GITHUB_REPOSITORY=prgrms-be-adv-devcourse/beadv6_6_let-sgpt_be
PG_SECRET_KEY=
# JWT(member)는 RSA(RS256) + JWKS 방식. 아래 값은 팀 공용 개발 키페어(운영에는 사용하지 말 것).
# 새로 발급하려면 (openssl 3.x 기준 - "openssl pkey -outform DER"는 PKCS8 래퍼가
# 벗겨진 채(PKCS1) 출력되는 버전이 있어 Java KeyFactory가 못 읽음. 아래처럼 pkcs8 서브커맨드로
# 변환해야 진짜 PKCS8 DER이 나온다):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl pkcs8 -topk8 -nocrypt -in private.pem -outform DER | base64 -w0   # -> JWT_PRIVATE_KEY
#   openssl pkey -in private.pem -pubout -outform DER | base64 -w0           # -> JWT_PUBLIC_KEY
JWT_KEY_ID=member-rsa-key-1
JWT_PRIVATE_
JWT_PUBLIC_
